# Providers to run: claude,codex,gemini
WARMUP_PROVIDERS=codex

# Local schedule. The runners check this config before sending a prompt.
WARMUP_SCHEDULE_ENABLED=true
WARMUP_TIMEZONE=Asia/Hong_Kong
WARMUP_HOURS=8,13,18
WARMUP_POLL_SECONDS=60
WARMUP_LOG_PATH=~/.local/state/ai-daily-warmup/warmup.log

WARMUP_PROMPT="Warmup. Don't think, just reply: OK"

# Set *_PATH to a custom executable path if you do not want to call the CLI
# command name directly.
# Set *_WORKDIR to run a provider from a stable workspace instead of a
# temporary directory.
# Set *_ENV_FILE to inject provider-specific environment variables.
CLAUDE_PATH=claude
CLAUDE_ARGS="--print --no-interactive"
CLAUDE_MODEL=
CLAUDE_CREDENTIAL_PATH=~/.claude/.credentials.json
CLAUDE_ENV_FILE=
CLAUDE_WORKDIR=

CODEX_PATH=codex
CODEX_ARGS=--quiet
CODEX_MODEL=
CODEX_CREDENTIAL_PATH=~/.codex/auth.json
CODEX_ENV_FILE=
CODEX_WORKDIR=

GEMINI_PATH=gemini
GEMINI_ARGS=
GEMINI_MODEL=
GEMINI_CREDENTIAL_PATH=~/.gemini/oauth_creds.json
GEMINI_ENV_FILE=
GEMINI_WORKDIR=
