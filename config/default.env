# Providers to run: claude,codex,gemini
WARMUP_PROVIDERS=codex

# Local schedule. The runners check this config before sending a prompt.
WARMUP_SCHEDULE_ENABLED=true
WARMUP_TIMEZONE=Asia/Hong_Kong
WARMUP_HOURS=8,13,18
WARMUP_SCHEDULER_INTERVAL_MINUTES=10
WARMUP_POLL_SECONDS=60
WARMUP_LOG_PATH=./logs/warmup.log
# Keep only the latest N tab-separated log rows.
WARMUP_LOG_MAX_ROWS=200
# Include this many lines of provider output in failed finish rows.
WARMUP_FAILURE_LOG_LINES=20
# Stores the last triggered schedule slot and timestamp.
WARMUP_STATE_PATH=./logs/warmup.state

# Minimum minutes between real warmup calls.
WARMUP_MIN_WINDOW_MINUTES=302  # delay for 2 min

# How many minutes after each configured WARMUP_HOURS time that slot remains
# eligible. Example: hour 13 with value 60 means 13:00-13:59 can count as the
# 13:00 slot. This is not added to WARMUP_MIN_WINDOW_MINUTES.
# WARMUP_SCHEDULER_INTERVAL_MINUTES <= WARMUP_SLOT_CATCHUP_MINUTES
WARMUP_SLOT_CATCHUP_MINUTES=60

WARMUP_PROMPT="Warmup. Don't think, just reply: OK"

# Set *_PATH to a custom executable path if you do not want to call the CLI command name directly.
# *_ARGS: Optional extra arguments to pass to the CLI.
# Set * _CREDENTIAL_PATH to blank to disable the warns/skips. A pre-check path. The script checks whether this file exists before running CLI. 
# *_MODEL: Optional model to pass to the CLI.
# *_WORKDIR: Working directory where Codex runs. If empty, the script creates a temporary directory for the warmup run.
# *_ENV_FILE: Optional extra env file to load only for Codex. Useful if your custom *_PATH script needs variables like usernames, tokens, etc

CLAUDE_PATH=claude
CLAUDE_ARGS="--print --no-interactive"
CLAUDE_CREDENTIAL_PATH=~/.claude/.credentials.json
CLAUDE_MODEL=
CLAUDE_WORKDIR=
CLAUDE_ENV_FILE=

CODEX_PATH=codex
CODEX_ARGS=exec --skip-git-repo-check --ephemeral --color never
CODEX_CREDENTIAL_PATH=~/.codex/auth.json
CODEX_MODEL=
CODEX_WORKDIR=
CODEX_ENV_FILE=

GEMINI_PATH=gemini
GEMINI_ARGS=
GEMINI_CREDENTIAL_PATH=~/.gemini/oauth_creds.json
GEMINI_MODEL=
GEMINI_WORKDIR=
GEMINI_ENV_FILE=
